import pandas as pd


def excel_remove_duplicates(input_file, output_file, sheet_name=0):
    """
    Excel 数据去重
    :param input_file: 输入Excel文件路径
    :param output_file: 输出去重后的文件路径
    :param sheet_name: 工作表名称/索引
    """
    # 读取Excel
    df = pd.read_excel(input_file, sheet_name=sheet_name)
    # 去重（保留第一次出现的行）
    df_clean = df.drop_duplicates()
    # 保存到新文件
    df_clean.to_excel(output_file, index=False)
    print(f"去重完成！原数据{len(df)}行 → 去重后{len(df_clean)}行")


# 用法示例
if __name__ == "__main__":
    excel_remove_duplicates("原始数据.xlsx", "去重后数据.xlsx")
